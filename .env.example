

# === Linear API ===

LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TOKEN=your_linear_api_key_here

# === Database (optional — skip if you don't need result persistence) ===
# Option A: Supabase REST API (works in Daytona where port 5432 is blocked)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
# Option B: Direct PostgreSQL (works when TCP 5432 is open)
PG_CONNECTION_STRING=postgresql://user:password@host:5432/dbname
ORG_ID=your_org_id
AGENT_ID=linear-task-manager

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_user_id

# === Runtime (auto-generated if not set) ===
RUN_ID=
