# Linear API (required)
# LINEAR_API_KEY is used by skills; LINEAR_TOKEN is used by linear-cli
# Set both to the same value (your Linear personal API key from Settings > API)
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TOKEN=your_linear_api_key_here

# Data Ingestion Service (required)
DATA_INGESTION_BASE_URL=https://ingestion-service-s45p.onrender.com
DATA_INGESTION_ORG_ID=your_org_id
DATA_INGESTION_AGENT_ID=linear-task-manager

# Telegram delivery (required)
# TELEGRAM_BOT_TOKEN: your bot token from @BotFather (used by OpenClaw's message() tool)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID: your numeric Telegram user ID (find via @userinfobot on Telegram)
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Runtime (auto-generated if not set)
RUN_ID=
